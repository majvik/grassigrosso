{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true,
      "unique": true
    },
    "collection": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::collection.collection"
    },
    "firmness": {
      "displayName": "Жесткость",
      "type": "enumeration",
      "required": true,
      "enum": ["мягкий", "средний", "жесткий", "разная_жесткость_сторон"],
      "default": "средний"
    },
    "firmness_option": {
      "displayName": "Жесткость (справочник)",
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::firmness-option.firmness-option"
    },
    "mattress_type": {
      "displayName": "Тип конструкции",
      "type": "enumeration",
      "required": true,
      "enum": ["пружинный", "беспружинный", "топер", "двухсторонние", "односторонние"],
      "default": "беспружинный"
    },
    "mattress_type_option": {
      "displayName": "Тип конструкции (справочник)",
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::mattress-type-option.mattress-type-option"
    },
    "height_cm": {
      "type": "decimal",
      "required": true
    },
    "max_load_kg": {
      "type": "integer",
      "required": true
    },
    "load_range": {
      "displayName": "Макс. нагрузка на спальное место",
      "type": "enumeration",
      "enum": ["до_120_кг", "до_160_кг", "свыше_160_кг"]
    },
    "load_range_option": {
      "displayName": "Макс. нагрузка на спальное место (справочник)",
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::load-range-option.load-range-option"
    },
    "height_range": {
      "displayName": "Высота матраса",
      "type": "enumeration",
      "enum": ["компактные_до_16_см", "средние_16_20_см", "высокие_свыше_20_см"]
    },
    "height_range_option": {
      "displayName": "Высота матраса (справочник)",
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::height-range-option.height-range-option"
    },
    "sizes": {
      "displayName": "Стандартизированные размеры",
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::mattress-size.mattress-size",
      "inversedBy": "products"
    },
    "fillings": {
      "displayName": "Состав / Наполнитель",
      "type": "enumeration",
      "enum": ["кокос", "латекс", "орто_пена", "с_эффектом_памяти", "нано_пена", "форплит"]
    },
    "filling_options": {
      "displayName": "Состав / Наполнитель (справочник)",
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::filling-option.filling-option"
    },
    "features": {
      "displayName": "Дополнительные особенности",
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::feature-option.feature-option"
    },
    "image_url": {
      "type": "string"
    },
    "media": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "sort_order": {
      "type": "integer",
      "default": 0
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag"
    }
  }
}
