{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true,
      "unique": true
    },
    "collection": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::collection.collection"
    },
    "firmness": {
      "displayName": "Жесткость",
      "type": "enumeration",
      "required": true,
      "enum": ["мягкий", "средний", "жесткий"],
      "default": "средний"
    },
    "mattress_type": {
      "displayName": "Тип конструкции",
      "type": "enumeration",
      "required": true,
      "enum": ["пружинный", "беспружинный", "топер"],
      "default": "беспружинный"
    },
    "height_cm": {
      "type": "decimal",
      "required": true
    },
    "max_load_kg": {
      "type": "integer",
      "required": true
    },
    "load_range": {
      "displayName": "Макс. нагрузка на спальное место",
      "type": "enumeration",
      "enum": ["до_90_кг", "до_110_кг", "до_130_кг", "до_150_кг", "свыше_150_кг"]
    },
    "height_range": {
      "displayName": "Высота матраса",
      "type": "enumeration",
      "enum": ["низкий", "средний", "высокий"]
    },
    "sizes": {
      "displayName": "Стандартизированные размеры",
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::mattress-size.mattress-size",
      "inversedBy": "products"
    },
    "fillings": {
      "displayName": "Состав / Наполнитель",
      "type": "enumeration",
      "enum": ["кокос", "латекс", "мемори", "ппу", "холкон"]
    },
    "features": {
      "displayName": "Дополнительные особенности",
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::feature-option.feature-option"
    },
    "image_url": {
      "type": "string"
    },
    "media": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "sort_order": {
      "type": "integer",
      "default": 0
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag"
    }
  }
}
