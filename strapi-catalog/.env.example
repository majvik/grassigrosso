# Шаблон в git. Реальные значения для strapi develop — в strapi-catalog/.env (не коммитится).
HOST=0.0.0.0
PORT=1337
# По умолчанию SQLite: strapi-catalog/.tmp/data.db (создаётся при первом запуске).
# Пустая БД → при открытии http://localhost:1337/admin редирект на /admin/auth/register-admin.
# Чтобы локально использовать репозиторный сид с админами и каталогом (как при первом старте Docker):
# DATABASE_FILENAME=database/seed/data.db
# Публичный URL сайта (как в браузере), если админка открывается через прокси Node — тот же хост, что и у витрины.
# Пример: https://majvik-grassigrosso-e3cd.twc1.net
STRAPI_PUBLIC_URL=
STRAPI_BEHIND_PROXY=true
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified
