{
  "name": "grassigrosso",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:strapi": "npm run develop --prefix strapi-catalog",
    "dev:api": "STRAPI_URL=http://127.0.0.1:1337 PORT=3000 NODE_ENV=development BOT_TOKEN=fake CHAT_ID=123 SMTP_HOST=127.0.0.1 SMTP_PORT=465 SMTP_SECURE=true SMTP_USER=test SMTP_PASS=test MAIL_FROM=test@example.com MAIL_TO=test@example.com DB_PATH=./data/leads-local-strapi-3000.db node server.cjs",
    "dev:all": "concurrently -k -n STRAPI,API,WEB -c yellow,green,blue \"npm:dev:strapi\" \"npm:dev:api\" \"npm:dev:web\"",
    "dev:stop": "kill-port 1337 3000 3200 5174",
    "build": "vite build",
    "preview": "vite preview",
    "new-page": "node scripts/new-page.mjs",
    "start": "node server.cjs"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "gsap": "^3.14.2",
    "http-proxy-middleware": "^3.0.5",
    "lenis": "^1.3.17",
    "nodemailer": "^8.0.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "kill-port": "^2.0.1",
    "vite": "^7.2.4"
  }
}
