# =============================================================================
# Корневой .env (не в git). На Timeweb задайте те же ИМЕНА переменных и значения.
# Локально: cp .env.example .env
# =============================================================================

# --- Telegram ---
BOT_TOKEN=your_bot_token_here
CHAT_ID=your_chat_id_here

# --- Фронт (Vite; подставляются при npm run build в Docker) ---
VITE_API_URL=/api/submit
VITE_YANDEX_MAPS_API_KEY=

# --- Почта (Yandex и др.; 465+SSL или 587+STARTTLS — как у провайдера) ---
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_USER=callback@grassigrosso.com
SMTP_PASS=your_app_password_here
MAIL_FROM=callback@grassigrosso.com
MAIL_TO=callback@grassigrosso.com

# --- Очередь доставки заявок (server.cjs) ---
QUEUE_FILE_PATH=./data/delivery-queue.json
QUEUE_RETRY_INTERVAL_MS=15000
QUEUE_BASE_RETRY_DELAY_MS=30000
QUEUE_MAX_RETRY_DELAY_MS=900000

# --- База лидов (lib/db.cjs); если не задано — ./data/leads.db от корня проекта ---
# DB_PATH=./data/leads.db

# --- Антиспам форм (если не заданы — см. server.cjs; при NODE_ENV≠production лимиты мягче для локальных тестов) ---
# SPAM_WINDOW_MS=600000
# SPAM_MAX_SUBMITS_PER_WINDOW=6
# SPAM_MIN_SUBMIT_INTERVAL_MS=8000
# SPAM_BLOCK_MS=1800000
# SPAM_MAX_COMMENT_LENGTH=2500
# SPAM_MAX_NAME_LENGTH=120
# SPAM_MAX_PHONE_LENGTH=40
# SPAM_MAX_EMAIL_LENGTH=160

# UNSUBSCRIBE_SECRET=  # по умолчанию используется BOT_TOKEN

# --- Публичный URL сайта (emails, canonical/OG при npm run build) ---
SITE_URL=https://grassigrosso.com

# --- CORS (через запятую; прод-домен + локальный dev при необходимости) ---
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# --- Node (Docker/Timeweb обычно задают в панели) ---
NODE_ENV=production
PORT=3000

# --- Strapi: витрина + прокси (server.cjs, nginx → /admin, /uploads) ---
# Внутри официального Docker-образа приложения Strapi слушает 127.0.0.1:1337
STRAPI_URL=http://127.0.0.1:1337
# Тот же хост/схема, что в браузере (без /admin) — ссылки в админке и за прокси
STRAPI_PUBLIC_URL=https://your-app.twc1.net
STRAPI_BEHIND_PROXY=true
# Отключить телеметрию Strapi (меньше запросов к analytics.strapi.io; в Docker задаётся start-services по умолчанию true)
# STRAPI_TELEMETRY_DISABLED=true
# Опционально: Bearer к API Strapi, если используете защищённые эндпоинты с бэкенда
# STRAPI_TOKEN=

# --- Strapi в Docker: секреты подхватывает scripts/start-services.sh из ОКРУЖЕНИЯ.
# Если НЕ задать на Timeweb — будут dev-строки из скрипта (сессии/токены «ломаются» при смене).
# Рекомендация: те же значения, что в strapi-catalog/.env локально (скопировать в панель).
# APP_KEYS=key1,key2,key3,key4
# API_TOKEN_SALT=
# ADMIN_JWT_SECRET=
# TRANSFER_TOKEN_SALT=
# JWT_SECRET=
# ENCRYPTION_KEY=
# STRAPI_DATABASE_FILENAME=/app/data/strapi/data.db
# STRAPI_PORT=1337
# STRAPI_HOST=0.0.0.0

# Медиа Strapi лежат в strapi-catalog/public/uploads/ (в репозитории).
