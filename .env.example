# Telegram Bot Configuration
BOT_TOKEN=your_bot_token_here
CHAT_ID=your_chat_id_here

# Email (Yandex SMTP) Configuration
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_USER=callback@grassigrosso.com
SMTP_PASS=your_app_password_here
MAIL_FROM=callback@grassigrosso.com
MAIL_TO=callback@grassigrosso.com

# Database + Queue Configuration
DB_PATH=./data/leads.db
QUEUE_RETRY_INTERVAL_MS=15000
QUEUE_BASE_RETRY_DELAY_MS=30000
QUEUE_MAX_RETRY_DELAY_MS=900000

# Anti-spam Configuration
SPAM_WINDOW_MS=600000
SPAM_MAX_SUBMITS_PER_WINDOW=6
SPAM_MIN_SUBMIT_INTERVAL_MS=8000
SPAM_BLOCK_MS=1800000
SPAM_MAX_COMMENT_LENGTH=2500
SPAM_MAX_NAME_LENGTH=120
SPAM_MAX_PHONE_LENGTH=40
SPAM_MAX_EMAIL_LENGTH=160

# Unsubscribe link signature (defaults to BOT_TOKEN)
# UNSUBSCRIBE_SECRET=your_secret_here

# Public site URL (emails, canonical/OG в HTML при сборке: npm run build подхватывает из .env)
# SITE_URL=https://grassigrosso.com

# CORS allowlist (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# Frontend API URL (for local development)
VITE_API_URL=/api/submit

# Yandex Maps (JavaScript API и HTTP Геокодер) – для карт на странице контактов
VITE_YANDEX_MAPS_API_KEY=

# Server Configuration
NODE_ENV=production
PORT=3000

# Strapi (catalog only for now)
# Example: https://cms.grassigrosso.com — внутренний URL для Node→Strapi (docker-сеть или localhost).
STRAPI_URL=
# Для Strapi в docker-compose: тот же публичный URL, что у витрины (без /admin), что и SITE_URL при одном домене.
# STRAPI_PUBLIC_URL=https://your-app.twc1.net
# Optional API token (recommended for production)
STRAPI_TOKEN=
